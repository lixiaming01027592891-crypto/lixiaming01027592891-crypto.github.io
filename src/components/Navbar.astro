---
export interface Props {
  transparent?: boolean;
}

const { transparent = true } = Astro.props;

const navItems = [
  { label: '首頁', href: '/' },
  { label: '關於我們', href: '/about/' },
  { label: '服務項目', href: '/#services' },
  { label: '服務地區', href: '/areas/' },
  { label: '照護知識', href: '/blog/' },
  { label: '常見問題', href: '/faq/' },
  { label: '聯絡我們', href: '/#contact' },
];

const phoneNumber = '0935-803-258';
const phoneLink = 'tel:+886935803258';
---

<header
  id="navbar"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-500',
    transparent ? 'bg-transparent' : 'bg-[#fcfaf6]/95 backdrop-blur-md shadow-md',
  ]}
>
  <nav class="section-container">
    <div class="flex items-center justify-between h-[72px] lg:h-[80px]">
      {/* Logo */}
      <a href="/" class="flex items-center gap-3 group">
        {/* YH Logo Icon */}
        <div class="w-10 h-10 lg:w-11 lg:h-11 bg-[#8b621f] rounded-lg flex items-center justify-center transition-transform duration-300 group-hover:scale-105">
          <span class="text-white font-bold text-base lg:text-lg tracking-tight" style="font-family: var(--font-serif)">YH</span>
        </div>
        <div class="flex flex-col">
          <span
            class="text-lg lg:text-xl font-semibold tracking-wide transition-colors duration-300"
            style="font-family: var(--font-serif)"
            class:list={[
              transparent ? 'text-[#fcfaf6]' : 'text-[#2b221c]',
            ]}
          >
            宇涵居家照護
          </span>
          <span
            class="text-[10px] lg:text-xs tracking-widest transition-colors duration-300"
            class:list={[
              transparent ? 'text-[#fcfaf6]/70' : 'text-[#6d5d50]',
            ]}
          >
            YUHAN HOMECARE
          </span>
        </div>
      </a>

      {/* Desktop Navigation */}
      <div class="hidden lg:flex items-center gap-8">
        <ul class="flex items-center gap-6 xl:gap-7">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-[15px] font-medium transition-colors duration-300 hover:text-[#8b621f] relative group py-2"
                class:list={[
                  transparent ? 'text-[#fcfaf6]/90' : 'text-[#2b221c]/80',
                ]}
              >
                {item.label}
                <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#8b621f] transition-all duration-300 group-hover:w-full" />
              </a>
            </li>
          ))}
        </ul>

        {/* Phone CTA Button */}
        <a
          href={phoneLink}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#8b621f] text-white text-[15px] font-medium rounded-lg transition-all duration-300 hover:bg-[#6d4f1a] hover:shadow-lg hover:shadow-[#8b621f]/20 hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          {phoneNumber}
        </a>
      </div>

      {/* Mobile Right Side: Phone + Hamburger */}
      <div class="flex items-center gap-3 lg:hidden">
        {/* Mobile Phone Button */}
        <a
          href={phoneLink}
          class="flex items-center gap-1.5 px-3 py-2 bg-[#8b621f] text-white text-sm font-medium rounded-lg transition-all duration-300 active:scale-95"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          <span class="hidden sm:inline">{phoneNumber}</span>
        </a>

        {/* Hamburger Button */}
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg transition-colors duration-300"
          class:list={[
            transparent ? 'text-[#fcfaf6] hover:bg-white/10' : 'text-[#2b221c] hover:bg-[#2b221c]/5',
          ]}
          aria-label="開啟選單"
          aria-expanded="false"
        >
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  {/* Mobile Menu */}
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-[72px] bg-[#fcfaf6] transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
  >
    <div class="px-6 py-8">
      <ul class="flex flex-col gap-2">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobile-nav-link block py-3.5 px-4 text-[17px] font-medium text-[#2b221c] rounded-lg transition-colors duration-200 hover:bg-[#efe5d5] hover:text-[#8b621f]"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-8 pt-6 border-t border-[#efe5d5]">
        <a
          href={phoneLink}
          class="flex items-center justify-center gap-2 w-full py-4 bg-[#8b621f] text-white text-lg font-medium rounded-xl transition-all duration-300 active:scale-[0.98]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          {phoneNumber}
        </a>
        <p class="text-center text-sm text-[#6d5d50] mt-3">24小時全年無休</p>
      </div>
    </div>
  </div>
</header>

<script>
  (function() {
    const navbar = document.getElementById('navbar');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIconOpen = document.getElementById('menu-icon-open');
    const menuIconClose = document.getElementById('menu-icon-close');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

    let isMenuOpen = false;

    // Scroll handler: change navbar background
    function handleScroll() {
      if (!navbar) return;
      const scrollY = window.scrollY || document.documentElement.scrollTop;
      const isTransparent = !navbar.classList.contains('scrolled');

      if (scrollY > 50) {
        navbar.classList.add('bg-[#fcfaf6]/95', 'backdrop-blur-md', 'shadow-md', 'scrolled');
        navbar.classList.remove('bg-transparent');

        // Update text colors for scrolled state
        const logoText = navbar.querySelectorAll('a[href="/"] span');
        logoText.forEach((el, i) => {
          if (i === 0) {
            el.classList.remove('text-[#fcfaf6]');
            el.classList.add('text-[#2b221c]');
          } else if (i === 1) {
            el.classList.remove('text-[#fcfaf6]/70');
            el.classList.add('text-[#6d5d50]');
          }
        });

        const navLinks = navbar.querySelectorAll('nav ul li a');
        navLinks.forEach(el => {
          el.classList.remove('text-[#fcfaf6]/90');
          el.classList.add('text-[#2b221c]/80');
        });

        const hamburgerBtn = navbar.querySelector('button');
        if (hamburgerBtn) {
          hamburgerBtn.classList.remove('text-[#fcfaf6]', 'hover:bg-white/10');
          hamburgerBtn.classList.add('text-[#2b221c]', 'hover:bg-[#2b221c]/5');
        }
      } else {
        navbar.classList.remove('bg-[#fcfaf6]/95', 'backdrop-blur-md', 'shadow-md', 'scrolled');
        navbar.classList.add('bg-transparent');

        // Restore text colors for transparent state
        const logoText = navbar.querySelectorAll('a[href="/"] span');
        logoText.forEach((el, i) => {
          if (i === 0) {
            el.classList.add('text-[#fcfaf6]');
            el.classList.remove('text-[#2b221c]');
          } else if (i === 1) {
            el.classList.add('text-[#fcfaf6]/70');
            el.classList.remove('text-[#6d5d50]');
          }
        });

        const navLinks = navbar.querySelectorAll('nav ul li a');
        navLinks.forEach(el => {
          el.classList.add('text-[#fcfaf6]/90');
          el.classList.remove('text-[#2b221c]/80');
        });

        const hamburgerBtn = navbar.querySelector('button');
        if (hamburgerBtn) {
          hamburgerBtn.classList.add('text-[#fcfaf6]', 'hover:bg-white/10');
          hamburgerBtn.classList.remove('text-[#2b221c]', 'hover:bg-[#2b221c]/5');
        }
      }
    }

    // Toggle mobile menu
    function toggleMenu() {
      isMenuOpen = !isMenuOpen;

      if (mobileMenu) {
        if (isMenuOpen) {
          mobileMenu.classList.remove('translate-x-full');
          mobileMenu.classList.add('translate-x-0');
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.add('translate-x-full');
          mobileMenu.classList.remove('translate-x-0');
          document.body.style.overflow = '';
        }
      }

      if (menuIconOpen && menuIconClose) {
        menuIconOpen.classList.toggle('hidden', isMenuOpen);
        menuIconClose.classList.toggle('hidden', !isMenuOpen);
      }

      if (menuBtn) {
        menuBtn.setAttribute('aria-expanded', String(isMenuOpen));
      }
    }

    // Initialize
    window.addEventListener('scroll', handleScroll, { passive: true });

    if (menuBtn) {
      menuBtn.addEventListener('click', toggleMenu);
    }

    mobileNavLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Initial check
    handleScroll();
  })();
</script>
