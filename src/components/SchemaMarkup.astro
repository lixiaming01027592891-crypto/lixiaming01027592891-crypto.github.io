---
import { COMPANY, SERVICE_AREAS } from '../consts';

export interface Props {
  type: 'LocalBusiness' | 'WebSite' | 'BreadcrumbList' | 'Article' | 'FAQPage' | 'Service';
  data?: Record<string, any>;
}

const { type, data = {} } = Astro.props;

const SITE_URL = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';

// 品牌預設資訊
const BRAND = {
  name: COMPANY.name,
  telephone: COMPANY.telLink.replace('tel:', ''),
  phoneDisplay: COMPANY.phone,
  address: COMPANY.address,
  url: SITE_URL,
  logo: `${SITE_URL}/images/logo.png`,
  image: `${SITE_URL}/images/og-image.jpg`,
  description: COMPANY.description,
  priceRange: COMPANY.priceRange,
  geo: COMPANY.geo,
  openingHours: COMPANY.openingHours,
  areaServed: SERVICE_AREAS,
  sameAs: [] as string[],
};

// 預設 LocalBusiness schema
const defaultLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: BRAND.name,
  description: BRAND.description,
  url: BRAND.url,
  logo: BRAND.logo,
  image: BRAND.image,
  telephone: BRAND.telephone,
  priceRange: BRAND.priceRange,
  address: {
    '@type': 'PostalAddress',
    streetAddress: BRAND.address.street,
    addressLocality: BRAND.address.district,
    addressRegion: BRAND.address.city,
    addressCountry: 'TW',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: BRAND.geo.latitude,
    longitude: BRAND.geo.longitude,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
  areaServed: BRAND.areaServed.map((area) => ({
    '@type': 'City',
    name: area,
  })),
  sameAs: BRAND.sameAs,
};

// 預設 WebSite schema
const defaultWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${BRAND.name}｜高雄居家看護推薦`,
  url: BRAND.url,
  description: BRAND.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${BRAND.url}/search?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

// 預設 BreadcrumbList schema
const defaultBreadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: '首頁',
      item: BRAND.url,
    },
  ],
};

// 預設 FAQPage schema
const defaultFAQPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [],
};

// 預設 Service schema
const defaultService = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: '居家照護服務',
  provider: {
    '@type': 'LocalBusiness',
    name: BRAND.name,
  },
  areaServed: {
    '@type': 'City',
    name: '高雄市',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: '居家照護服務項目',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '長者陪伴照護' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '日常生活協助' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '居家安全觀察' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '復健與回診陪同' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '家庭照護溝通' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '短期與彈性支援' } },
    ],
  },
};

// 預設 Article schema
const defaultArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: '',
  description: '',
  image: '',
  datePublished: '',
  dateModified: '',
  author: {
    '@type': 'Organization',
    name: BRAND.name,
  },
  publisher: {
    '@type': 'Organization',
    name: BRAND.name,
    logo: {
      '@type': 'ImageObject',
      url: BRAND.logo,
    },
  },
};

// 根據 type 選擇對應的 schema
function getSchema() {
  switch (type) {
    case 'LocalBusiness':
      return { ...defaultLocalBusiness, ...data };
    case 'WebSite':
      return { ...defaultWebSite, ...data };
    case 'BreadcrumbList':
      if (data.items) {
        return {
          ...defaultBreadcrumbList,
          itemListElement: data.items.map((item: any, index: number) => ({
            '@type': 'ListItem',
            position: index + 1,
            name: item.name,
            item: item.url,
          })),
        };
      }
      return { ...defaultBreadcrumbList, ...data };
    case 'FAQPage':
      if (data.questions) {
        return {
          ...defaultFAQPage,
          mainEntity: data.questions.map((q: any) => ({
            '@type': 'Question',
            name: q.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: q.answer,
            },
          })),
        };
      }
      return { ...defaultFAQPage, ...data };
    case 'Article':
      return { ...defaultArticle, ...data };
    case 'Service':
      return { ...defaultService, ...data };
    default:
      return defaultLocalBusiness;
  }
}

const schema = getSchema();
const schemaJSON = JSON.stringify(schema, null, 0);
---

<script type="application/ld+json" set:html={schemaJSON} />
