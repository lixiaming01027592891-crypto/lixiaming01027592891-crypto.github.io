            <div class="w-1 h-8 bg-[#8b621f] rounded-full"></div>
            <h2 class="text-xl sm:text-2xl font-bold text-[#2b221c]">{cat.name}</h2>
          </div>
          <div class="space-y-4">
            {cat.items.map((item, idx) => (
              <details class="group bg-[#fcfaf6] rounded-xl border border-[#efe5d5] overflow-hidden cursor-pointer">
                <summary class="flex items-center justify-between p-5 sm:p-6 list-none">
                  <div class="flex items-center gap-3 pr-4">
                    <span class="text-[#8b621f] font-bold text-sm">Q</span>
                    <span class="font-medium text-[#2b221c]">{item.q}</span>
