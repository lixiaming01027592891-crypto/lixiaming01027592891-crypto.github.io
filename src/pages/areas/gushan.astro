---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 鼓山區服務',
  description: '高雄鼓山區居家看護服務，提供到府照護。鼓山區依山傍海，環境優美，鄰近高醫、市立聯合醫院，適合長者休養居住。',
  url: 'https://www.yuhan-homecare.com.tw/areas/gushan',
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '鼓山區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市鼓山區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄鼓山區居家看護｜到府照護服務｜宇涵"
  description="高雄鼓山區居家看護服務推薦。鼓山區依山傍海環境優美，宇涵提供到府看護、居家照顧、術後照護、失能照護等專業服務。鄰近高醫、市立聯合醫院。"
  keywords="鼓山區居家看護,鼓山區看護,鼓山區到府照顧,高雄鼓山區看護,鼓山區居家照顧,鼓山區24小時看護,鼓山區長照"
  schema={schema}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-gushan-hero.jpg" alt="高雄鼓山區西子灣海景" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">鼓山區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄鼓山區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">鼓山區擁有高雄最美的山海景致，環境寧靜宜人，是長者居住休養的理想選擇。宇涵居家照護提供專業到府看護，讓鼓山區的家庭安心無憂。</p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">鼓山區 — 依山傍海的宜居天堂</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            鼓山區位於高雄市西側，北接左營、南鄰苓雅，是全高雄最具自然景觀的行政區。區內擁有西子灣、打狗英國領事館、國立中山大學等知名地標，依山傍海，空氣清新，環境寧靜，非常適合長者居住休養。根據統計，鼓山區人口約14萬人，65歲以上長者比例穩定成長。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            鼓山區的住宅以透天厝與海景大樓為主，許多退休人士選擇在此安度晚年。區內的鼓山三路、華榮路一帶商圈發展成熟，市場、超市、藥局、診所一應俱全。捷運橘線貫穿區內，加上哈瑪星輕軌，交通便利。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務涵蓋鼓山區全境，包括凹子底、龍華、明誠、美術館特區、西子灣、哈瑪星等區域。我們熟悉鼓山區的山坡地形與社區分布，能夠快速派遣看護人員到達府上，提供貼心專業的照護服務。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-gushan.jpg" alt="高雄鼓山區西子灣日落" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">鼓山區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: '日常生活照顧', desc: '進食、沐浴、穿脫、如廁、移位、服藥提醒等全方位生活協助。' },
          { title: '照護服務服務', desc: '傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、用藥管理等專業護理。' },
          { title: '失能失智照護', desc: '針對失能失智長者的專業照護計畫與安全陪伴。' },
          { title: '術後返家照護', desc: '手術後返家照護、復健協助、傷口觀察與營養調理。' },
          { title: '24小時全天候', desc: '日間照顧、夜間陪伴、臨時代班，彈性安排。' },
          { title: '就醫陪同服務', desc: '陪同至鼓山區內外醫療院所就診，協助掛號與醫療溝通。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">鼓山區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄醫學大學附設醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市三民區自由一路100號（鄰近鼓山區）</p>
          <p class="text-sm text-[#6d5d50]">南台灣最具規模的醫學中心，許多鼓山區居民的就醫首選。宇涵看護經常配合高醫出院患者的居家照護。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">市立聯合醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市中華一路68號</p>
          <p class="text-sm text-[#6d5d50]">市立綜合醫院，距離鼓山區近，提供內科、外科、復健科等多元醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄市立民生醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市鼓山區民生一路</p>
          <p class="text-sm text-[#6d5d50]">位於鼓山區內的市立醫院，提供急診、門診與住院服務，是鼓山區居民就近就醫的好選擇。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">鼓山區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市鼓山區鼓山二路37號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理、長照諮詢等服務。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼鼓山區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">熟悉鼓山區地形環境</h3><p class="text-[#6d5d50] text-sm">了解鼓山區的山坡地形與道路狀況，快速到達各社區。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">善用優質自然環境</h3><p class="text-[#6d5d50] text-sm">陪伴長者至西子灣、美術館公園散步，結合環境優勢促進身心健康。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">鄰近醫療資源整合</h3><p class="text-[#6d5d50] text-sm">與高醫、民生醫院等醫療機構建立良好銜接，確保照護連續性。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">彈性服務時間</h3><p class="text-[#6d5d50] text-sm">提供臨時、短期、長期照護選擇，依照家庭需求靈活安排。</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">鼓山區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">一通電話，我們即刻安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
