---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 苓雅區服務',
  description: '高雄苓雅區居家看護服務，提供24小時到府照護。苓雅區為高雄文化商業重鎮，宇涵提供專業居家照顧、術後照護、失能照護等服務。',
  url: 'https://www.yuhan-homecare.com.tw/areas/lingya',
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '苓雅區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市苓雅區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄苓雅區居家看護｜專業到府照護｜宇涵"
  description="高雄苓雅區居家看護服務推薦。苓雅區為高雄文化商業重鎮，宇涵提供24小時到府看護、居家照顧、術後照護、失能照護、失智照護等專業服務。"
  keywords="苓雅區居家看護,苓雅區看護,苓雅區到府照顧,高雄苓雅區看護,苓雅區居家照顧,苓雅區臨時看護,苓雅區24小時看護"
  schema={schema}
>
  <!-- Hero -->
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-lingya-hero.jpg" alt="高雄苓雅區文化中心" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">苓雅區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄苓雅區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">苓雅區是高雄文化與商業的核心區域，宇涵居家照護深耕在地，提供專業、溫暖的到府看護服務，讓苓雅區的家庭安心無憂。</p>
    </div>
  </section>

  <!-- 區域簡介 -->
  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">苓雅區 — 高雄文化商業重鎮</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            苓雅區位於高雄市中心，是南台灣最重要的文化與商業樞紐。區內擁有高雄文化中心、苓雅市場、眾百貨商圈，以及密集的住宅社區。根據統計，苓雅區人口約17萬人，是高雄人口密度最高的區域之一，其中65歲以上長者占比持續攀升。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            苓雅區的住宅型態多元，從早期透天厝到現代化電梯大樓皆有，許多家庭選擇讓長輩在原居地安老。加上區內生活機能完善，市場、公園、醫療院所一應俱全，是長者居住的理想地點。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務範圍涵蓋苓雅區全境，從文化中心周邊到五福商圈，從自強夜市到武廟一帶，我們的看護團隊都能快速到達，為您的家人提供貼心的照護。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-lingya.jpg" alt="高雄苓雅區文化中心" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 服務內容 -->
  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">苓雅區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', title: '日常生活照顧', desc: '進食、沐浴、穿脫衣物、如廁、移位、服藥提醒等全方位生活協助。' },
          { icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', title: '照護服務', desc: '傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、用藥管理等專業護理服務。' },
          { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01', title: '失智照護', desc: '失智長者專業陪伴、認知活動設計、情緒支持、安全看護。' },
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: '24小時照護', desc: '全天候專業看護，包含日間照顧與夜間陪伴，隨時因應突發狀況。' },
          { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: '術後照護', desc: '手術後返家照護、復健協助、傷口觀察、營養調理等。' },
          { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', title: '陪伴服務', desc: '就醫陪同、散步陪伴、社交活動、心理支持與情緒關懷。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
            </div>
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 附近醫院 -->
  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">苓雅區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">高雄醫學大學附設醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市三民區自由一路100號</p>
          <p class="text-sm text-[#6d5d50]">南台灣最具規模的醫學中心，苓雅區居民主要就醫選擇。宇涵經常承接高醫出院患者的居家照護需求。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">高雄市立聯合醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市中華一路68號</p>
          <p class="text-sm text-[#6d5d50]">市立綜合醫院，距離苓雅區近，許多苓雅區長者在此就診與住院。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">阮綜合醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市苓雅區成功一路162號</p>
          <p class="text-sm text-[#6d5d50]">位於苓雅區內的綜合醫院，提供婦產科、內科、外科等多元醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">苓雅區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市苓雅區四維二路128號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健檢、慢性病管理，是苓雅區長者日常保健的重要據點。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 為什麼選擇 -->
  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼苓雅區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">快速派遣，最短30分鐘到達</h3><p class="text-[#6d5d50] text-sm">從新興區出發，快速抵達苓雅區各角落，緊急需求也能迅速回應。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">熟悉苓雅區醫療網絡</h3><p class="text-[#6d5d50] text-sm">長期配合高醫、阮綜合醫院等醫療機構，熟悉轉診與出院流程。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">多元住宅經驗</h3><p class="text-[#6d5d50] text-sm">無論電梯大樓或透天厝，看護人員皆有豐富的苓雅區各類住宅服務經驗。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">文化活動陪伴</h3><p class="text-[#6d5d50] text-sm">熟悉苓雅區公園、文化中心等設施，可陪伴長者參與社區活動。</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">苓雅區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">一通電話，我們即刻安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
