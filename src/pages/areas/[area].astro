---
import MainLayout from '../../layouts/MainLayout.astro';
import { areas, type AreaData } from '../../data/areas';
import { COMPANY } from '../../consts';

export async function getStaticPaths() {
  return areas.map((area) => ({
    params: { area: area.slug },
    props: { area },
  }));
}

interface Props {
  area: AreaData;
}

const { area } = Astro.props;
const canonicalURL = new URL(`/areas/${area.slug}/`, Astro.site);

const schema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `${COMPANY.name} - ${area.district}服務`,
  description: area.schemaDescription,
  url: canonicalURL.toString(),
  telephone: COMPANY.telLinkAlt.replace('tel:', ''),
  address: {
    '@type': 'PostalAddress',
    addressLocality: '高雄市',
    addressRegion: area.district,
    addressCountry: 'TW',
  },
  areaServed: {
    '@type': 'City',
    name: `高雄市${area.district}`,
  },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: COMPANY.priceRange,
};
if (area.geo) {
  schema.geo = { '@type': 'GeoCoordinates', latitude: area.geo.latitude, longitude: area.geo.longitude };
}

const breadcrumbItems = [
  { name: '首頁', url: new URL('/', Astro.site).toString() },
  { name: '服務地區', url: new URL('/areas/', Astro.site).toString() },
  { name: area.district, url: canonicalURL.toString() },
];
---

<MainLayout
  title={area.pageTitle}
  description={area.metaDescription}
  keywords={area.keywords}
  canonicalURL={canonicalURL.toString()}
  schema={schema}
  breadcrumbItems={breadcrumbItems}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src={area.heroImage} alt={area.heroImageAlt} class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li>
          <li aria-hidden="true"><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas/" class="hover:text-[#8b621f] transition-colors">服務地區</a></li>
          <li aria-hidden="true"><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]" aria-current="page">{area.district}</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">
        高雄{area.district}居家看護服務
      </h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">
        {area.heroSubtitle}
      </p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">{area.introHeading}</h2>
          {area.introParagraphs.map((para) => (
            <p class="text-[#6d5d50] leading-relaxed mb-4 last:mb-0">{para}</p>
          ))}
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src={area.mainImage} alt={area.mainImageAlt} class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">
        {area.district}居家看護服務內容
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {area.services.map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">
        {area.district}附近醫院與醫療資源
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {area.hospitals.map((hospital) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-1">{hospital.name}</h3>
            {hospital.address && <p class="text-sm text-[#6d5d50] mb-2">{hospital.address}</p>}
            <p class="text-sm text-[#6d5d50]">{hospital.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">
        為什麼{area.district}家庭選擇{COMPANY.name}？
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {area.whyChoose.map((reason, index) => (
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold" aria-hidden="true">
              {index + 1}
            </div>
            <div>
              <h3 class="font-bold text-[#2b221c] mb-1">{reason.title}</h3>
              <p class="text-[#6d5d50] text-sm">{reason.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">{area.ctaHeadline}</h2>
      <p class="text-[#efe5d5] mb-8">{area.ctaSubtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={COMPANY.telLinkAlt}
          aria-label={`撥打 ${COMPANY.phoneAlt} 諮詢${area.district}居家看護`}
          class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {COMPANY.phoneAlt}
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg"
        >
          免費諮詢表單
        </a>
      </div>
    </div>
  </section>
</MainLayout>
