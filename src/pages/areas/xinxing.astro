---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 新興區服務',
  description: '高雄新興區居家看護服務，提供24小時到府照護。位於新興區中心，鄰近高雄醫學大學附設醫院、市立聯合醫院，交通便利。',
  url: new URL('/areas/xinxing', Astro.site).toString(),
  telephone: '+886978788886',
  address: {
    '@type': 'PostalAddress',
    addressLocality: '高雄市',
    addressRegion: '新興區',
    addressCountry: 'TW',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '22.6304',
    longitude: '120.3132',
  },
  areaServed: {
    '@type': 'City',
    name: '高雄市新興區',
  },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄新興區居家看護｜24小時到府照護推薦｜宇涵"
  description="高雄新興區居家看護服務推薦。宇涵居家照護位於新興區，鄰近高醫、市立聯合醫院，提供24小時到府看護、居家照顧、術後照護、失能照護等專業服務。"
  keywords="新興區居家看護,新興區看護,新興區到府照顧,高雄新興區看護,新興區居家照顧,新興區臨時看護,新興區24小時看護,新興區醫院看護"
  schema={schema}
>
  <!-- Hero Section -->
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-xinxing-hero.jpg" alt="高雄新興區街景" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li>
          <li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li>
          <li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">新興區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">
        高雄新興區居家看護服務
      </h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">
        宇涵居家照護坐落於新興區精華地段，熟悉區內每一條街道與醫療資源，提供最快30分鐘到府的專業看護服務。
      </p>
    </div>
  </section>

  <!-- 區域簡介 -->
  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">新興區 — 高雄市中心的心脏</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            新興區位於高雄市中心，是高雄最早發展的商業區之一。區內擁有熱鬧的六合夜市、美麗島捷運站、以及眾多政府機關與商業大樓。根據統計，新興區常住人口約5萬人，加上每日流動人口，是市區活動最頻繁的區域之一。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            新興區的長者人口比例逐年上升，許多家庭面臨長輩照護的需求。由於區內公寓大廈與老舊住宅並存，地形平坦、交通便利，非常適合長者居住，也讓居家看護服務的需求日益增加。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護位於新興區，對區內各里、各社區的環境瞭若指掌，能夠快速派遣看護人員到達服務地點，為新興區的家庭提供最即時、貼心的照護服務。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-xinxing.jpg" alt="高雄新興區美麗島捷運站周邊" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 服務內容 -->
  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">新興區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">日常生活照顧</h3>
          <p class="text-[#6d5d50] text-sm leading-relaxed">協助進食、沐浴、穿脫衣物、如廁、移動、服藥提醒等基礎生活照護。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">術後傷口照護</h3>
          <p class="text-[#6d5d50] text-sm leading-relaxed">專業傷口傷口敷料更換（依醫囑）、管線護理、術後復健協助，確保術後恢復順利。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">失能失智照護</h3>
          <p class="text-[#6d5d50] text-sm leading-relaxed">針對失能、失智長者的專業照護，包括認知訓練、情緒安撫、安全陪伴。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">緊急狀況處理</h3>
          <p class="text-[#6d5d50] text-sm leading-relaxed">看護人員具備基礎急救知識，能在緊急情況下採取正確應對措施。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">24小時全天候服務</h3>
          <p class="text-[#6d5d50] text-sm leading-relaxed">提供臨時、短期、長期照護服務，依照您的需求彈性安排時間。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <div class="w-12 h-12 bg-[#8b621f]/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#8b621f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#2b221c] mb-2">醫療機構陪同</h3>
          <p class="text-[#6d5d50] text-sm leading-relaxed">陪同就醫、看診、檢查，協助家屬與醫療人員溝通。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 附近醫院 -->
  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">新興區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5] flex items-start space-x-4">
          <div class="w-14 h-14 bg-[#8b621f]/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-xl font-bold text-[#8b621f]">醫</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄醫學大學附設醫院</h3>
            <p class="text-sm text-[#6d5d50] mb-2">高雄市三民區自由一路100號（近新興區邊界）</p>
            <p class="text-sm text-[#6d5d50]">高雄最具規模的醫學中心之一，提供急診、住院、手術等完整醫療服務。宇涵看護經常配合高醫出院患者的居家照護需求。</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5] flex items-start space-x-4">
          <div class="w-14 h-14 bg-[#8b621f]/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-xl font-bold text-[#8b621f]">醫</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄市立聯合醫院</h3>
            <p class="text-sm text-[#6d5d50] mb-2">高雄市中華一路68號（近新興區）</p>
            <p class="text-sm text-[#6d5d50]">市立綜合醫院，設有內科、外科、復健科等。許多新興區長者在此就診，宇涵可提供出院後接續照護服務。</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5] flex items-start space-x-4">
          <div class="w-14 h-14 bg-[#8b621f]/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-xl font-bold text-[#8b621f]">所</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#2b221c] mb-1">新興區衛生所</h3>
            <p class="text-sm text-[#6d5d50] mb-2">高雄市新興區中正三路115號</p>
            <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理等基層醫療服務，是長者日常健康管理的重要據點。</p>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5] flex items-start space-x-4">
          <div class="w-14 h-14 bg-[#8b621f]/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="text-xl font-bold text-[#8b621f]">鐵</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#2b221c] mb-1">交通優勢</h3>
            <p class="text-sm text-[#6d5d50] mb-2">捷運紅橘線交會 — 美麗島站</p>
            <p class="text-sm text-[#6d5d50]">新興區擁有高雄捷運最重要的轉運站，加上眾多公車路線，宇涵看護人員可快速抵達區內任何地點。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 為什麼選擇宇涵 -->
  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼新興區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div>
            <h3 class="font-bold text-[#2b221c] mb-1">宇涵所在地，最快30分鐘到府</h3>
            <p class="text-[#6d5d50] text-sm">宇涵居家照護位於新興區，對區內環境最為熟悉，能夠在最短時間內派遣看護人員到達府上。</p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div>
            <h3 class="font-bold text-[#2b221c] mb-1">熟稔區內醫療資源</h3>
            <p class="text-[#6d5d50] text-sm">長期配合高醫、市立聯合醫院等醫療機構，了解各院流程，能妥善安排轉診與出院準備。</p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div>
            <h3 class="font-bold text-[#2b221c] mb-1">在地化服務，溝通零距離</h3>
            <p class="text-[#6d5d50] text-sm">看護人員多為在地居民，熟悉新興區的語言文化，能與長者及家屬建立良好互動關係。</p>
          </div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div>
            <h3 class="font-bold text-[#2b221c] mb-1">彈性排班，隨叫隨到</h3>
            <p class="text-[#6d5d50] text-sm">提供臨時、短期、長期彈性選擇。不論是臨時有事需要代班，還是長期照護需求，都能配合。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">新興區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">我們位於新興區，最快30分鐘內即可安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
