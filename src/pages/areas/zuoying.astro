---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 左營區服務',
  description: '高雄左營區居家看護服務，提供24小時到府照護派遣。鄰近高雄榮民總醫院、國軍左營醫院，是北高雄重要的照護服務區域。',
  url: 'https://www.yuhan-homecare.com.tw/areas/zuoying',
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '左營區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市左營區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄左營區居家看護｜24小時照護派遣｜宇涵"
  description="高雄左營區居家看護服務推薦。鄰近高雄榮總、國軍左營醫院，提供24小時到府看護、居家照顧、術後照護、失能照護等專業服務。"
  keywords="左營區居家看護,左營區看護,左營區到府照顧,高雄左營區看護,左營區居家照顧,左營區24小時看護,左營區醫院看護"
  schema={schema}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-zuoying-hero.jpg" alt="高雄左營區蓮池潭" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">左營區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄左營區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">左營區擁有北高雄最豐富的醫療資源，宇涵居家照護提供24小時到府看護派遣，讓左營區的家庭隨時獲得專業照護。</p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">左營區 — 北高雄醫療重鎮</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            左營區是高雄市面積最大的行政區之一，人口約20萬人，也是北高雄最重要的居住與醫療中心。區內擁有左營舊城、蓮池潭等著名景點，更重要的是聚集了高雄榮民總醫院、國軍左營醫院等大型醫療機構。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            左營區的居住環境以高品質著稱，從早期眷村改建到現代化重劃區，綠地公園眾多，空氣品質良好，是許多長者選擇定居的地區。高鐵左營站、捷運紅線也讓區內交通十分便利。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務涵蓋左營區全境，包括左營舊城、果貿社區、自由黃昏市場周邊、蓮池潭附近、以及高鐵特區等區域。我們與區內多家醫院建立良好的轉診與照護銜接機制，確保病患出院後能得到無縫的居家照護。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-zuoying.jpg" alt="高雄左營區蓮池潭風景" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">左營區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: '日常生活照顧', desc: '協助進食、沐浴、穿脫衣物、如廁、移位、服藥提醒等基礎生活照護。' },
          { title: '傷口與照護服務', desc: '專業傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、術後復健協助。' },
          { title: '失能失智照護', desc: '針對失能、失智長者的專業照護計畫，包含認知訓練與安全陪伴。' },
          { title: '24小時全天候服務', desc: '日間照顧、夜間陪伴、臨時代班，依照需求彈性安排。' },
          { title: '醫院到居家銜接', desc: '配合榮總、國軍左營醫院出院流程，無縫銜接居家照護。' },
          { title: '復健協助', desc: '協助長者執行復健運動、陪同復健科門診、輔具使用指導。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">左營區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄榮民總醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市左營區大中一路386號</p>
          <p class="text-sm text-[#6d5d50]">國內最具規模的榮民醫院之一，醫療水準頂尖。宇涵經常承接榮總出院患者的居家照護，熟悉其醫療流程與用藥規範。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">國軍左營醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市左營區軍校路553號</p>
          <p class="text-sm text-[#6d5d50]">國軍醫院對外開放就診，設有急診、內科、外科等科別，是左營區北部居民重要的醫療選擇。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">國軍高雄總醫院左營分院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市左營區勝利路11號</p>
          <p class="text-sm text-[#6d5d50]">提供多元化的醫療專科服務，包括心臟內科、神經內科、骨科等，設備完善。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">左營區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市左營區左營大路478號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理、長照服務諮詢等基層醫療服務。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼左營區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">熟悉榮總醫療流程</h3><p class="text-[#6d5d50] text-sm">長期配合高雄榮總，了解出院流程與醫囑，確保病患返家後得到延續性照護。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">覆蓋左營全區域</h3><p class="text-[#6d5d50] text-sm">從果貿社區到高鐵特區，從舊城到蓮池潭，無死角服務左營區每一個角落。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">優質環境適合養老</h3><p class="text-[#6d5d50] text-sm">左營區綠地多、空氣好，看護人員可陪同長者至蓮池潭、公園散步運動。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">24小時快速調度</h3><p class="text-[#6d5d50] text-sm">不論白天或深夜，一通電話即可安排看護人員到府，解決照護空窗期。</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">左營區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">我們提供24小時到府看護派遣服務，一通電話即刻安排。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
