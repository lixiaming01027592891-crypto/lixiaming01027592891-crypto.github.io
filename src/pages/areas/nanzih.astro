---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 楠梓區服務',
  description: '高雄楠梓區居家看護服務，提供到府照護。楠梓區為北高雄發展迅速的住宅區，宇涵提供專業居家看護、居家照顧、術後照護等服務。',
  url: 'https://www.yuhan-homecare.com.tw/areas/nanzih',
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '楠梓區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市楠梓區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄楠梓區居家看護｜到府照護服務｜宇涵"
  description="高雄楠梓區居家看護服務推薦。楠梓區為北高雄發展迅速的住宅區，宇涵提供到府看護、居家照顧、術後照護、失能照護等專業服務。"
  keywords="楠梓區居家看護,楠梓區看護,楠梓區到府照顧,高雄楠梓區看護,楠梓區居家照顧,楠梓區24小時看護"
  schema={schema}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-nanzih-hero.jpg" alt="高雄楠梓區街景" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">楠梓區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄楠梓區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">楠梓區是北高雄發展最迅速的住宅區，學術風氣鼎盛、住宅環境優質。宇涵居家照護提供楠梓區專業到府看護服務，守護每一位長者的健康。</p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">楠梓區 — 北高雄的文教住宅區</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            楠梓區位於高雄市最北端，人口約19萬人，是北高雄人口最多的行政區。區內擁有國立高雄大學、國立高雄科技大學楠梓校區、高雄市立楠梓高級中學等多所學府，學術風氣鼎盛，也有「高雄文教區」之稱。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            楠梓區近年來發展迅速，現代化住宅社區林立，加上捷運紅線的開通，與市區的連結更加緊密。區內的楠梓都會公園、德民黃昏市場等設施，為居民提供了優質的生活環境。許多退休教職員與專業人士選擇在此居住。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務涵蓋楠梓區全境，包括楠梓車站周邊、後勁、右昌、德民、土庫、援中港等區域。我們熟悉楠梓區的社區分布，能夠快速派遣看護人員到達府上。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-nanzih.jpg" alt="高雄楠梓區楠梓都會公園" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">楠梓區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: '日常生活照顧', desc: '進食、沐浴、穿脫、如廁、移位、服藥提醒等基礎生活照護。' },
          { title: '照護服務服務', desc: '傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、用藥管理等專業護理。' },
          { title: '失能失智照護', desc: '針對失能失智長者的專業照護計畫與安全陪伴。' },
          { title: '術後返家照護', desc: '手術後返家照護、復健協助、傷口觀察與營養調理。' },
          { title: '24小時全天候', desc: '日間照顧、夜間陪伴、臨時代班，彈性安排。' },
          { title: '就醫陪同服務', desc: '陪同至楠梓區內外醫療院所就診，協助醫療溝通。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">楠梓區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">國軍高雄總醫院左營分院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市楠梓區軍校路553號</p>
          <p class="text-sm text-[#6d5d50]">鄰近楠梓區的國軍醫院，提供急診、內科、外科、復健科等完整醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">楠梓區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市楠梓區楠梓路264號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理、長照諮詢等基層醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">惠仁醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市楠梓區德民路</p>
          <p class="text-sm text-[#6d5d50]">楠梓區在地醫院，提供內科、外科、婦產科等醫療服務，居民就近就醫方便。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄榮民總醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市左營區大中一路386號（鄰近楠梓區）</p>
          <p class="text-sm text-[#6d5d50]">南台灣頂尖醫療中心，距離楠梓區近，許多楠梓區居民的就醫選擇。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼楠梓區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">北高雄快速服務</h3><p class="text-[#6d5d50] text-sm">利用捷運與高速公路，快速抵達楠梓區各區域，包括後勁、右昌、援中港等地。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">了解楠梓社區特性</h3><p class="text-[#6d5d50] text-sm">熟悉楠梓區各住宅社區，能針對不同社區環境提供適合的照護服務。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">公園綠地活動</h3><p class="text-[#6d5d50] text-sm">可陪同長者至楠梓都會公園散步運動，結合環境優勢促進身心健康。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">醫療轉診銜接</h3><p class="text-[#6d5d50] text-sm">與榮總等醫療機構建立良好銜接，確保出院後的居家照護品質。</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">楠梓區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">一通電話，我們即刻安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
