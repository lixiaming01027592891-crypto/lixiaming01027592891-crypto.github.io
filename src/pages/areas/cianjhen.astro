---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 前鎮區服務',
  description: '高雄前鎮區居家看護服務，提供24小時照護。前鎮區為南高雄工商重鎮，宇涵提供專業到府看護、居家照顧、術後照護等服務。',
  url: new URL('/areas/cianjhen', Astro.site).toString(),
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '前鎮區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市前鎮區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄前鎮區居家看護｜24小時照護｜宇涵"
  description="高雄前鎮區居家看護服務推薦。前鎮區為南高雄工商重鎮，宇涵提供24小時到府看護、居家照顧、術後照護、失能照護等專業服務。"
  keywords="前鎮區居家看護,前鎮區看護,前鎮區到府照顧,高雄前鎮區看護,前鎮區居家照顧,前鎮區24小時看護"
  schema={schema}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-cianjhen-hero.jpg" alt="高雄前鎮區夜景" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">前鎮區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄前鎮區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">前鎮區是南高雄的工商重鎮，人口密集、生活機能完善。宇涵居家照護提供前鎮區24小時專業看護派遣服務，隨時為您與家人提供支持。</p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">前鎮區 — 南高雄的活力之都</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            前鎮區位於高雄市南端，人口約19萬人，是高雄重要的工商業區。區內擁有亞洲新灣區、高雄展覽館、夢時代購物中心等現代化設施，同時也有許多傳統社區。前鎮區的發展歷史悠久，從早期的漁港聚落發展為今日的現代化都市區域。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            前鎮區的住宅型態相當多元，從臨港區的公寓到夢時代周邊的大樓社區皆有。隨著人口老化與家庭結構改變，前鎮區對居家看護的需求也持續成長。許多工廠退休的勞工在此居住，需要長期的照護支持。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務涵蓋前鎮區全境，包括前鎮、草衙、佛公、崗山仔、凱旋等區域。我們熟悉前鎮區的道路與社區分布，能夠快速到達任何需要服務的地點。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-cianjhen.jpg" alt="高雄前鎮區夢時代商圈" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">前鎮區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: '日常生活照顧', desc: '進食、沐浴、穿脫、如廁、移位、服藥提醒等基礎生活照護。' },
          { title: '照護服務服務', desc: '傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、用藥管理等專業護理。' },
          { title: '失能失智照護', desc: '針對失能失智長者的專業照護計畫與安全陪伴。' },
          { title: '術後返家照護', desc: '手術後返家照護、復健協助、傷口觀察與營養調理。' },
          { title: '24小時全天候', desc: '日間照顧、夜間陪伴、臨時代班，彈性安排。' },
          { title: '就醫陪同服務', desc: '陪同至小港醫院等醫療院所就診，協助醫療溝通。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">前鎮區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">小港醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市前鎮區（近小港區邊界）</p>
          <p class="text-sm text-[#6d5d50]">鄰近前鎮區的綜合醫院，提供急診、內科、外科等醫療服務，是前鎮區居民主要就醫選擇之一。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">前鎮區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市前鎮區沱江街183號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理、長照諮詢等基層醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄市立小港醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市小港區山明路482號</p>
          <p class="text-sm text-[#6d5d50]">市立綜合醫院，距離前鎮區近，提供完整的急診與住院醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">亞東紀念醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市前鎮區（近前鎮區）</p>
          <p class="text-sm text-[#6d5d50]">提供多專科門診與住院服務，設備完善。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼前鎮區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">南高雄快速服務</h3><p class="text-[#6d5d50] text-sm">熟悉前鎮區道路與交通，能夠快速到達前鎮、草衙、佛公等各區域。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">24小時隨時待命</h3><p class="text-[#6d5d50] text-sm">不論白天或深夜，一通電話即可安排看護人員到府服務。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">了解在地需求</h3><p class="text-[#6d5d50] text-sm">前鎮區有許多退休勞工家庭，我們了解其特殊照護需求。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">彈性排班制度</h3><p class="text-[#6d5d50] text-sm">臨時、短期、長期照護均可安排，滿足不同家庭的多元需求。</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">前鎮區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">一通電話，我們即刻安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
