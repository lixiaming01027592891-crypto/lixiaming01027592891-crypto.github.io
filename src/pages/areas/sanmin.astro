---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 三民區服務',
  description: '高雄三民區居家看護服務推薦。三民區是高雄人口最多的行政區，擁有高醫、長庚等頂尖醫療機構。宇涵提供專業到府看護服務。',
  url: new URL('/areas/sanmin', Astro.site).toString(),
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '三民區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市三民區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄三民區居家看護｜專業看護推薦｜宇涵"
  description="高雄三民區居家看護服務推薦。三民區為高雄人口最多的行政區，擁有高醫、長庚等醫療機構。宇涵提供到府看護、居家照顧、術後照護、失能照護等專業服務。"
  keywords="三民區居家看護,三民區看護,三民區到府照顧,高雄三民區看護,三民區居家照顧,三民區24小時看護,三民區長照"
  schema={schema}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-sanmin-hero.jpg" alt="高雄三民區街景" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">三民區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄三民區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">三民區是高雄人口最多的行政區，醫療資源豐富。宇涵居家照護在三民區提供快速到府的專業看護服務，滿足多元化的照護需求。</p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">三民區 — 高雄人口最多的核心區域</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            三民區位於高雄市地理中心，人口超過34萬人，是全高雄人口最多的行政區。區內擁有高雄火車站、捷運紅橘線交會，是高雄最重要的交通樞紐。三民區也聚集了高雄最豐富的醫療資源，包括高雄醫學大學附設醫院、長庚紀念醫院高雄分院等多家大型醫療機構。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            三民區的住宅型態多元，從早期的傳統社區到現代化電梯大樓應有盡有，涵蓋了不同年齡層與經濟條件的居民。隨著人口老化，三民區對居家看護服務的需求也日益增加。許多家庭需要專業的看護人員來照顧術後、失能或失智的家人。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務涵蓋三民區全境，包括高雄車站周邊、大順商圈、鼎山夜市、天祥路、明誠路沿線等各區域。我們熟悉三民區的地理環境與醫療資源分布，能夠在最短時間內派遣適合的看護人員到府服務。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-sanmin.jpg" alt="高雄三民區街景" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">三民區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: '日常生活照顧', desc: '進食、沐浴、穿脫、如廁、移位、服藥提醒等基礎生活照護。' },
          { title: '照護服務服務', desc: '傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、用藥管理等專業護理。' },
          { title: '失能失智照護', desc: '針對失能失智長者的專業照護計畫與安全陪伴。' },
          { title: '術後返家照護', desc: '手術後返家照護、復健協助、傷口觀察與營養調理。' },
          { title: '24小時全天候', desc: '日間照顧、夜間陪伴、臨時代班，彈性安排時間。' },
          { title: '就醫陪同服務', desc: '陪同至三民區各大醫院就診，協助掛號與醫療溝通。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">三民區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄醫學大學附設醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市三民區自由一路100號</p>
          <p class="text-sm text-[#6d5d50]">高雄最具規模的醫學中心，三民區居民主要就醫選擇。宇涵長期配合高醫出院患者的居家照護。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">長庚紀念醫院高雄分院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市鳳山區 Top 1</p>
          <p class="text-sm text-[#6d5d50]">長庚醫療體系在高雄的分院，提供高品質醫療服務，許多三民區居民會跨區就診。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">國軍高雄總醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市三民區建國路一段10號</p>
          <p class="text-sm text-[#6d5d50]">國軍醫院對外開放，提供內科、外科、急診等醫療服務，位於三民區核心地帶交通便利。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">三民區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市三民區大順二路468號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理、長照諮詢等基層醫療服務。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼三民區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">覆蓋三民區全境</h3><p class="text-[#6d5d50] text-sm">從高雄車站到鼎山、從明誠路到大順路，無死角服務三民區每一個角落。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">豐富醫療資源整合</h3><p class="text-[#6d5d50] text-sm">長期配合高醫、國軍高雄總醫院等醫療機構，確保出院照護無縫銜接。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">交通便利快速到達</h3><p class="text-[#6d5d50] text-sm">利用捷運與主要幹道，看護人員可快速到達三民區任何地方。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">多元社區經驗</h3><p class="text-[#6d5d50] text-sm">無論傳統社區或現代大樓，宇涵看護都有豐富的三民區各類住宅服務經驗。</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">三民區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">一通電話，我們即刻安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
