---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '宇涵居家照護 - 小港區服務',
  description: '高雄小港區居家看護服務，提供專業看護派遣。小港區為南高雄重要工業住宅區，宇涵提供到府看護、居家照顧、術後照護等服務。',
  url: 'https://www.yuhan-homecare.com.tw/areas/siaogang',
  telephone: '+886978788886',
  address: { '@type': 'PostalAddress', addressLocality: '高雄市', addressRegion: '小港區', addressCountry: 'TW' },
  areaServed: { '@type': 'City', name: '高雄市小港區' },
  serviceType: '居家看護、居家照顧、到府照護',
  priceRange: '$$',
};
---

<MainLayout
  title="高雄小港區居家看護｜專業看護派遣｜宇涵"
  description="高雄小港區居家看護服務推薦。小港區為南高雄重要工業住宅區，宇涵提供專業看護派遣、到府看護、居家照顧、術後照護、失能照護等服務。"
  keywords="小港區居家看護,小港區看護,小港區到府照顧,高雄小港區看護,小港區居家照顧,小港區24小時看護"
  schema={schema}
>
  <section class="relative bg-[#2b221c] py-16 lg:py-24">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/area-siaogang-hero.jpg" alt="高雄小港區風景" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="麵包屑" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#efe5d5]/80">
          <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li><a href="/areas" class="hover:text-[#8b621f] transition-colors">服務地區</a></li><li><span class="text-[#efe5d5]/40">/</span></li>
          <li class="text-[#fcfaf6]">小港區</li>
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#fcfaf6] mb-4">高雄小港區居家看護服務</h1>
      <p class="text-lg text-[#efe5d5] max-w-2xl leading-relaxed">小港區是南高雄的重要門戶，擁有國際機場與工業區。宇涵居家照護提供小港區專業到府看護服務，守護每一位長者的健康與安全。</p>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-4">小港區 — 南高雄的重要門戶</h2>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            小港區位於高雄市南端，人口約16萬人，是台灣南部最重要的海空運輸樞紐。區內擁有高雄國際機場與高雄港，工業與住宅並存，發展相當蓬勃。小港區的居民許多在工廠工作一輩子，退休後在此安度晚年。
          </p>
          <p class="text-[#6d5d50] leading-relaxed mb-4">
            小港區的醫療資源相當不錯，擁有市立小港醫院等多家醫療機構。加上近年來的都市更新，許多新的住宅社區興建，生活品質不斷提升。捷運紅線的開通也讓小港區與市區的連結更加便利。
          </p>
          <p class="text-[#6d5d50] leading-relaxed">
            宇涵居家照護服務涵蓋小港區全境，包括小港、桂林、漢民、二苓、廈莊等區域。我們熟悉小港區的社區分布與道路環境，能夠快速到達任何需要服務的地點。
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/area-siaogang.jpg" alt="高雄小港區風景" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">小港區居家看護服務內容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: '日常生活照顧', desc: '進食、沐浴、穿脫、如廁、移位、服藥提醒等基礎生活照護。' },
          { title: '照護服務服務', desc: '傷口傷口敷料更換（依醫囑）、管線護理、血糖血壓監測、用藥管理等專業護理。' },
          { title: '失能失智照護', desc: '針對失能失智長者的專業照護計畫與安全陪伴。' },
          { title: '術後返家照護', desc: '手術後返家照護、復健協助、傷口觀察與營養調理。' },
          { title: '24小時全天候', desc: '日間照顧、夜間陪伴、臨時代班，彈性安排。' },
          { title: '就醫陪同服務', desc: '陪同至小港醫院等醫療院所就診，協助醫療溝通。' },
        ].map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
            <h3 class="text-lg font-bold text-[#2b221c] mb-2">{item.title}</h3>
            <p class="text-[#6d5d50] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#fcfaf6] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8">小港區附近醫院與醫療資源</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄市立小港醫院</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市小港區山明路482號</p>
          <p class="text-sm text-[#6d5d50]">市立綜合醫院，提供完整的急診、內科、外科、復健科等醫療服務，是小港區最重要的醫療機構。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">小港區衛生所</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市小港區翠亨南路202號</p>
          <p class="text-sm text-[#6d5d50]">提供預防接種、健康檢查、慢性病管理、長照諮詢等基層醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">高雄國際機場醫療站</h3>
          <p class="text-sm text-[#6d5d50] mb-2">高雄市小港區中山四路2號</p>
          <p class="text-sm text-[#6d5d50]">提供緊急醫療救護與基本醫療服務。</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-[#efe5d5]">
          <h3 class="text-lg font-bold text-[#2b221c] mb-1">區域醫療協作</h3>
          <p class="text-sm text-[#6d5d50]">與前鎮區、小港區各大醫療院所建立良好的轉診與照護銜接機制。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#efe5d5]/20 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-[#2b221c] mb-8 text-center">為什麼小港區家庭選擇宇涵？</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">1</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">南高雄遠端服務</h3><p class="text-[#6d5d50] text-sm">宇涵服務範圍涵蓋小港區，利用捷運與主要幹道快速到達。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">2</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">了解退休勞工需求</h3><p class="text-[#6d5d50] text-sm">小港區有許多工廠退休勞工，我們了解其特殊的健康照護需求。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">3</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">24小時快速派遣</h3><p class="text-[#6d5d50] text-sm">不論白天或深夜，一通電話即可安排看護人員到府服務。</p></div>
        </div>
        <div class="flex items-start space-x-4">
          <div class="w-10 h-10 bg-[#8b621f] text-white rounded-full flex items-center justify-center flex-shrink-0 font-bold">4</div>
          <div><h3 class="font-bold text-[#2b221c] mb-1">醫療資源整合</h3><p class="text-[#6d5d50] text-sm">與小港醫院等醫療機構建立良好銜接，確保照護連續性。</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#2b221c] py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[#fcfaf6] mb-4">小港區居家看護需求？立即聯絡宇涵</h2>
      <p class="text-[#efe5d5] mb-8">一通電話，我們即刻安排專業看護到府服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0978788886" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white font-semibold rounded-lg hover:bg-[#8b621f]/90 transition-colors text-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0978-788-886
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] font-semibold rounded-lg hover:bg-[#fcfaf6]/10 transition-colors text-lg">免費諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
