---
import MainLayout from '../../layouts/MainLayout.astro';

const title = "服務項目｜高雄居家看護、醫院看護、長期照護服務內容";
const description = "宇涵提供完整的居家看護服務，包括長者陪伴、日常生活協助、失智照護、術後照顧、醫院看護及臨時看護派遣。";
const canonicalURL = new URL("/services/", Astro.site);

const services = [
  {
    title: "居家看護",
    href: "/services/home-care/",
    image: "/images/hero-banner.jpg",
    desc: "專業到府照護服務，協助長者日常生活起居、飲食照顧、身體清潔等，讓長者在家也能享有專業照護。",
    tags: ["24小時", "日間照護", "長期照護"]
  },
  {
    title: "醫院看護",
    href: "/services/hospital-care/",
    image: "/images/service-rehab.jpg",
    desc: "醫院病房看護派遣，陪伴住院病患、協助就醫流程、照顧日常生活需求，減輕家屬負擔。",
    tags: ["病房陪伴", "手術照護", "24小時輪班"]
  },
  {
    title: "長者陪伴",
    href: "/services/elderly-care/",
    image: "/images/service-elderly.jpg",
    desc: "為獨居或需要陪伴的長者提供溫暖陪伴服務，包含散步、聊天、活動協助，減少孤獨感。",
    tags: ["日間陪伴", "活動協助", "情感支持"]
  },
  {
    title: "失智照護",
    href: "/services/dementia-care/",
    image: "/images/blog-dementia.jpg",
    desc: "專業失智症照護，運用實證照護技巧，穩定長者情緒、延緩退化，提供安全的生活環境。",
    tags: ["專業訓練", "情緒安撫", "認知活動"]
  },
  {
    title: "術後照顧",
    href: "/services/post-surgery/",
    image: "/images/blog-postsurgery.jpg",
    desc: "手術後返家照護，協助傷口觀察與清潔照護、用藥提醒、復健協助，幫助患者安心休養。",
    tags: ["傷口觀察與清潔照護", "復健協助", "用藥管理"]
  },
  {
    title: "臨時看護",
    href: "/services/temporary-care/",
    image: "/images/service-temporary.jpg",
    desc: "彈性短期看護派遣，適合家屬臨時有事、看護休假或急需求的情境，快速媒合到府。",
    tags: ["即時派遣", "短期服務", "彈性時間"]
  }
];
---

<MainLayout title={title} description={description} canonicalURL={canonicalURL}>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "宇涵服務項目",
      "description": "高雄居家看護、醫院看護、長期照護等完整服務內容",
      "url": "https://yuhanhomecare.com/services/",
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "居家看護", "url": "https://yuhanhomecare.com/services/home-care/"},
          {"@type": "ListItem", "position": 2, "name": "醫院看護", "url": "https://yuhanhomecare.com/services/hospital-care/"},
          {"@type": "ListItem", "position": 3, "name": "長者陪伴", "url": "https://yuhanhomecare.com/services/elderly-care/"},
          {"@type": "ListItem", "position": 4, "name": "失智照護", "url": "https://yuhanhomecare.com/services/dementia-care/"},
          {"@type": "ListItem", "position": 5, "name": "術後照顧", "url": "https://yuhanhomecare.com/services/post-surgery/"},
          {"@type": "ListItem", "position": 6, "name": "臨時看護", "url": "https://yuhanhomecare.com/services/temporary-care/"}
        ]
      }
    }
  </script>

  <!-- Hero -->
  <section class="relative bg-[#fcfaf6] overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-[#efe5d5] opacity-30 rounded-bl-[100px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 relative">
      <div class="max-w-3xl">
        <nav aria-label="breadcrumb" class="mb-4">
          <ol class="flex text-sm text-[#6d5d50]">
            <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li>
            <li class="mx-2">/</li>
            <li class="text-[#2b221c] font-medium" aria-current="page">服務項目</li>
          </ol>
        </nav>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#2b221c] mb-4 leading-tight">服務項目</h1>
        <p class="text-lg sm:text-xl text-[#6d5d50] leading-relaxed">宇涵提供完整的居家照護服務，從日常陪伴到專業照護服務，滿足您家庭的全方位需求</p>
      </div>
    </div>
  </section>

  <!-- 六大服務 -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-[#2b221c] mb-4">六大專業服務</h2>
        <p class="text-[#6d5d50] max-w-2xl mx-auto">針對不同照護需求，提供量身訂做的專業服務方案</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {services.map(service => (
          <a href={service.href} class="group bg-[#fcfaf6] rounded-2xl overflow-hidden hover:shadow-xl transition-shadow duration-300 block">
            <div class="relative overflow-hidden">
              <img 
                src={service.image} 
                alt={`${service.title}服務`}
                class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                width="600"
                height="224"
              />
              <div class="absolute top-4 right-4 bg-[#8b621f] text-white text-sm px-3 py-1 rounded-full font-medium">了解更多 →</div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-[#2b221c] mb-2 group-hover:text-[#8b621f] transition-colors">{service.title}</h3>
              <p class="text-[#6d5d50] leading-relaxed mb-4 text-sm">{service.desc}</p>
              <div class="flex flex-wrap gap-2">
                {service.tags.map(tag => (
                  <span class="text-xs bg-[#efe5d5] text-[#4a3525] px-3 py-1 rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 費用區間 -->
  <section class="py-16 lg:py-20 bg-[#fcfaf6]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-[#2b221c] mb-4">服務費用參考</h2>
        <p class="text-[#6d5d50]">實際費用依個案需求與服務時段調整，歡迎來電諮詢詳細報價</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-[#2b221c] text-[#fcfaf6]">
                <th class="px-6 py-4 font-semibold">服務類型</th>
                <th class="px-6 py-4 font-semibold">服務時段</th>
                <th class="px-6 py-4 font-semibold">費用區間</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#efe5d5]">
              <tr class="hover:bg-[#fcfaf6] transition-colors">
                <td class="px-6 py-4 font-medium text-[#2b221c]">居家看護</td>
                <td class="px-6 py-4 text-[#6d5d50]">12小時 / 24小時</td>
                <td class="px-6 py-4 text-[#8b621f] font-semibold">$2,200 - $2,800 /日</td>
              </tr>
              <tr class="hover:bg-[#fcfaf6] transition-colors">
                <td class="px-6 py-4 font-medium text-[#2b221c]">醫院看護</td>
                <td class="px-6 py-4 text-[#6d5d50]">12小時 / 24小時</td>
                <td class="px-6 py-4 text-[#8b621f] font-semibold">$2,200 - $2,800 /日</td>
              </tr>
              <tr class="hover:bg-[#fcfaf6] transition-colors">
                <td class="px-6 py-4 font-medium text-[#2b221c]">長者陪伴</td>
                <td class="px-6 py-4 text-[#6d5d50]">4小時 / 8小時 / 日間</td>
                <td class="px-6 py-4 text-[#8b621f] font-semibold">$1,600 - $2,200 /日</td>
              </tr>
              <tr class="hover:bg-[#fcfaf6] transition-colors">
                <td class="px-6 py-4 font-medium text-[#2b221c]">失智照護</td>
                <td class="px-6 py-4 text-[#6d5d50]">12小時 / 24小時</td>
                <td class="px-6 py-4 text-[#8b621f] font-semibold">$2,400 - $3,000 /日</td>
              </tr>
              <tr class="hover:bg-[#fcfaf6] transition-colors">
                <td class="px-6 py-4 font-medium text-[#2b221c]">術後照顧</td>
                <td class="px-6 py-4 text-[#6d5d50]">依療程週數安排</td>
                <td class="px-6 py-4 text-[#8b621f] font-semibold">$2,200 - $2,800 /日</td>
              </tr>
              <tr class="hover:bg-[#fcfaf6] transition-colors">
                <td class="px-6 py-4 font-medium text-[#2b221c]">臨時看護</td>
                <td class="px-6 py-4 text-[#6d5d50]">彈性時段</td>
                <td class="px-6 py-4 text-[#8b621f] font-semibold">$200 - $250 /時</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-center text-sm text-[#6d5d50] py-4 bg-[#efe5d5] bg-opacity-30">以上為參考費用，實際金額依照護內容、個案狀況及服務時段有所調整</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-[#2b221c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-[#fcfaf6] mb-4">需要照護諮詢？</h2>
      <p class="text-[#efe5d5] mb-8 leading-relaxed">每個家庭的需求都不同，宇涵提供免費諮詢服務，幫助您找到適合的照護方案。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0935803258" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white rounded-full font-semibold text-lg hover:bg-[#6d4a18] transition-colors duration-300 shadow-lg">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          0935-803-258
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] rounded-full font-semibold text-lg hover:bg-[#efe5d5] hover:text-[#2b221c] transition-colors duration-300">
          免費諮詢
        </a>
      </div>
    </div>
  </section>
</MainLayout>
