    <!-- Content -->
    <div class="bg-[#fcfaf6] py-12 lg:py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 引言 -->
        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-[#6d5d50] leading-relaxed mb-8">
            失智症是一種逐漸進行的神經退化性疾病，不僅影響患者的記憶力與認知功能，更深深衝擊整個家庭的生活。根據台灣失智症協會的統計，台灣目前失智症人口已超過30萬人，且隨著人口老化持續增加。對於許多家庭來說，選擇讓失智長者留在家中接受照護，是最能維持其生活品質與尊嚴的方式。本文將提供完整的失智症居家照護指南，幫助照護者掌握實用的照護技巧與知識。
          </p>

          <!-- 目錄 -->
          <div class="bg-[#efe5d5]/30 rounded-xl p-6 mb-10">
            <h2 class="text-xl font-bold text-[#2b221c] mb-4">目錄</h2>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
