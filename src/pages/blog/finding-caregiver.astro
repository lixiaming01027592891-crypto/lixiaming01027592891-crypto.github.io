const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "父親出院回家後，那些醫院不會教你的照護細節｜高雄醫院居家看護與照護中心安排心得",
  "description": "分享出院前後需要注意的準備工作，以及如何安排居家看護服務。",
  "image": new URL("/images/blog-finding-caregiver-1.jpg", Astro.site).toString(),
  "author": {"@type": "Organization", "name": "宇涵居家照護"},
  "publisher": {
    "@type": "Organization",
    "name": "宇涵居家照護",
    "logo": {"@type": "ImageObject", "url": new URL("/logo.svg", Astro.site).toString()}
