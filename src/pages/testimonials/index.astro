---
import MainLayout from '../../layouts/MainLayout.astro';

const title = "客戶見證｜高雄居家看護推薦評價｜宇涵";
const description = "來看看宇涵居家照護的客戶真實評價與推薦，了解我們如何用專業與愛心贏得每個家庭的信任。";
const canonicalURL = new URL("/testimonials/", Astro.site);

const testimonials = [
  {
    name: "陳小姐",
    service: "長者陪伴",
    rating: 5,
    content: "我們家爺爺需要長期陪伴，試過好幾家看護中心，最後找到宇涵。他們的看護真的非常細心，會主動跟我們溝通爺爺每天的狀況，也很願意配合我們家庭的作息和需求調整。爺爺現在每天都笑得很開心，我們全家都很感謝！",
    highlight: "溝通細心，願意配合家庭調整"
  },
  {
    name: "林先生",
    service: "失智照護",
    rating: 5,
    content: "媽媽有失智症，之前換過好幾個看護，常常因為人員流動要重新適應。自從找了宇涵之後，團隊非常穩定，看護人員流動率很低。而且他們會即時回報媽媽的狀況，讓我在外工作也很安心。看護對失智長者的照顧方式非常專業，看得出來受過良好訓練。",
    highlight: "團隊穩定，即時回報"
  },
  {
    name: "張太太",
    service: "居家協助",
    rating: 5,
    content: "宇涵安排的看護跟我們家人的互動非常自然，不會有那種生疏的感覺。看護很有耐心，對長輩說話的語氣也很溫柔。而且公司在安排時間上很有彈性，我們臨時需要調整時段，他們都會盡量配合。非常推薦給需要居家看護的家庭！",
    highlight: "互動自然、安排彈性"
  },
  {
    name: "王女士",
    service: "術後照顧",
    rating: 5,
    content: "爸爸做完膝關節手術回家休養，我們完全不知道怎麼照顧術後病人。幸好找到宇涵，他們的看護對術後照護非常熟悉，傷口觀察、復健協助、用藥提醒都做得很好。爸爸恢復得很順利，回診時醫生還稱讚傷口癒合得很好。真的很感謝宇涵的專業服務！",
    highlight: "專業細心，恢復順利"
  },
  {
    name: "李先生",
    service: "醫院看護",
    rating: 5,
    content: "母親住院期間，我和太太都要上班，沒辦法全天在醫院陪伴。透過宇涵安排了24小時醫院看護，看護非常有經驗，熟悉醫院的流程，把母親照顧得很好。每天都會主動傳訊息告訴我們母親的狀況，讓我們可以安心工作。這筆錢花得非常值得！",
    highlight: "24小時照護讓我們安心"
  },
  {
    name: "趙小姐",
    service: "臨時看護",
    rating: 5,
    content: "原本照顧奶奶的看護臨時請假三天，我著急得不知道怎麼辦。打電話給宇涵，從提出需求到看護到府只花了四個小時！臨時派遣來的看護也很專業，馬上接手照顧奶奶，完全沒有銜接問題。服務品質和態度都非常好，以後有臨時需求一定會再找他們！",
    highlight: "緊急派遣速度快，服務品質好"
  }
];

const stats = [
  { number: "500+", label: "累積服務家庭" },
  { number: "98%", label: "客戶滿意度" },
  { number: "4.9", label: "平均評分" },
  { number: "5年", label: "平均照護經驗" }
];

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "ReviewPage",
  "name": "宇涵客戶見證",
  "description": "高雄居家看護推薦評價",
  "url": new URL("/testimonials/", Astro.site).toString(),
  "mainEntity": {
    "@type": "Organization",
    "name": "宇涵居家照護",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "500",
      "bestRating": "5"
    }
  }
};
---

<MainLayout title={title} description={description} canonicalURL={canonicalURL}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(reviewSchema)} />

  <!-- Hero -->
  <section class="relative bg-[#fcfaf6] overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-[#efe5d5] opacity-30 rounded-bl-[100px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 relative">
      <div class="max-w-3xl">
        <nav aria-label="breadcrumb" class="mb-4">
          <ol class="flex text-sm text-[#6d5d50]">
            <li><a href="/" class="hover:text-[#8b621f] transition-colors">首頁</a></li>
            <li class="mx-2">/</li>
            <li class="text-[#2b221c] font-medium" aria-current="page">客戶見證</li>
          </ol>
        </nav>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#2b221c] mb-4 leading-tight">客戶見證</h1>
        <p class="text-lg sm:text-xl text-[#6d5d50] leading-relaxed">每一個好評，都是對我們用心服務的最大肯定</p>
      </div>
    </div>
  </section>

  <!-- 統計數據 -->
  <section class="py-12 bg-[#2b221c]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-bold text-[#8b621f] mb-2">{stat.number}</div>
            <div class="text-sm text-[#efe5d5]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 見證卡片 -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-[#2b221c] mb-4">來自客戶的真實回饋</h2>
        <p class="text-[#6d5d50] max-w-2xl mx-auto">我們珍惜每一位客戶的信任與肯定，這些真實的分享是我們不斷進步的動力</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map(item => (
          <div class="bg-[#fcfaf6] rounded-2xl p-8 flex flex-col h-full">
            <!-- 星級 -->
            <div class="flex gap-1 mb-4">
              {Array.from({ length: item.rating }).map(() => (
                <svg class="w-5 h-5 text-[#8b621f]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
              ))}
            </div>
            <!-- 標籤 -->
            <span class="inline-block bg-[#8b621f] bg-opacity-10 text-[#8b621f] text-xs px-3 py-1 rounded-full font-medium mb-3 w-fit">{item.service}</span>
            <!-- 引言 -->
            <p class="text-[#2b221c] leading-relaxed mb-4 flex-grow">「{item.content}」</p>
            <!-- 重點 -->
            <div class="bg-[#efe5d5] bg-opacity-40 rounded-lg p-3 mb-4">
              <p class="text-sm text-[#8b621f] font-medium">{item.highlight}</p>
            </div>
            <!-- 署名 -->
            <div class="flex items-center gap-3 mt-auto">
              <div class="w-10 h-10 bg-[#2b221c] text-[#fcfaf6] rounded-full flex items-center justify-center font-bold">{item.name[0]}</div>
              <span class="font-medium text-[#2b221c]">{item.name}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Google評價連結 -->
  <section class="py-16 lg:py-20 bg-[#fcfaf6]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-[#2b221c] mb-4">更多真實評價</h2>
      <p class="text-[#6d5d50] mb-8 leading-relaxed">歡迎到 Google 查看宇涵居家照護的更多客戶評價與推薦。您的每一則評價對我們都是莫大的鼓勵！</p>
      <a href="https://www.google.com/search?q=宇涵居家照護" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 bg-white border-2 border-[#2b221c] text-[#2b221c] rounded-full font-semibold text-lg hover:bg-[#2b221c] hover:text-[#fcfaf6] transition-colors duration-300 shadow-sm">
        <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        查看 Google 評價
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-[#2b221c]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-[#fcfaf6] mb-4">加入我們的滿意客戶行列</h2>
      <p class="text-[#efe5d5] mb-8 leading-relaxed">讓宇涵用專業與愛心，為您的家人提供優質的照護服務。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0935803258" class="inline-flex items-center justify-center px-8 py-4 bg-[#8b621f] text-white rounded-full font-semibold text-lg hover:bg-[#6d4a18] transition-colors shadow-lg">撥打 0935-803-258</a>
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#efe5d5] text-[#fcfaf6] rounded-full font-semibold hover:bg-[#efe5d5] hover:text-[#2b221c] transition-colors">填寫諮詢表單</a>
      </div>
    </div>
  </section>
</MainLayout>
